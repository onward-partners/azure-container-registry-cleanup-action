{
  "name": "@i40mc/azure-container-registry-cleanup-action",
  "private": true,
  "description": "This action cleans up old image tags in an Azure Container Registry",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint src/**/*.ts",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i40mc/azure-container-registry-cleanup-action.git"
  },
  "keywords": [
    "actions",
    "azure",
    "acr"
  ],
  "author": "scomans",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@azure/container-registry": "^1.1.2",
    "@azure/identity": "^4.13.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-github": "^6.0.0",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "prettier": "3.8.1",
    "rollup": "^4.60.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
